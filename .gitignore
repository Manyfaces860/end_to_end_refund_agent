# ==========================================
# 1. ROOT & INFRASTRUCTURE (Terraform / OS)
# ==========================================
.terraform/
*.tfstate
*.tfstate.backup
.terraform.lock.hcl

# Local credential safety (Prevents local service account key leaks)
gcp_key.json
*.pem
gcp-key.json
github-deployer-key.json
*.json.local

# OS files
.DS_Store
Thumbs.db
desktop.ini

# ==========================================
# 2. BACKEND (Python / FastAPI)
# ==========================================
backend/__pycache__/
backend/*.py[cod]
backend/*$py.class
backend/.pytest_cache/
backend/.env
backend/venv/
backend/env/
backend/logs/
backend/test/

# ==========================================
# 3. FRONTEND (Node / Next.js / Package Managers)
# ==========================================
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.cache/
frontend/.vercel
frontend/*.tsbuildinfo

# Package manager lock/cache overrides (if using Yarn Berry)
frontend/.pnp
frontend/.pnp.*
frontend/.yarn/*
!frontend/.yarn/patches
!frontend/.yarn/plugins
!frontend/.yarn/releases
!frontend/.yarn/versions

# ==========================================
# 4. TESTING & DEBUG LOGS
# ==========================================
coverage/
/coverage
dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*